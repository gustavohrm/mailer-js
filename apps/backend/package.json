{
  "name": "@mailer/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:unit": "vitest run src/",
    "test:integration": "vitest run tests/integration/",
    "test:watch": "vitest",
    "prestart": "npm run build",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "fastify": "^5.6.1",
    "nodemailer": "^7.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
